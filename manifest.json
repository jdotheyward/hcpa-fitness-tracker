<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#C4A84A" />
    <meta name="description" content="Heyward Upper Body Fitness Tracker — spin, resistance bands, form guide, session log." />

    <!-- PWA / Android -->
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="application-name" content="HCPA Fit" />

    <!-- PWA / iOS -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="HCPA Fit" />

    <!-- Icons -->
    <link rel="icon" href="%PUBLIC_URL%/icons/icon-192.png" />
    <link rel="apple-touch-icon" href="%PUBLIC_URL%/icons/icon-192.png" />
    <link rel="manifest" href="%PUBLIC_URL%/manifest.json" />

    <title>HCPA Upper Body Tracker</title>

    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #1A1A1A;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overscroll-behavior-y: contain;
      }
      /* Prevent iOS bounce scroll */
      html, body { height: 100%; overflow: hidden; }
      #root { height: 100%; overflow-y: auto; -webkit-overflow-scrolling: touch; }
    </style>
  </head>
  <body>
    <noscript>You need to enable JavaScript to run this app.</noscript>
    <div id="root"></div>
  </body>
</html>
